{
  "name": "signalk-updater-server",
  "version": "0.1.1",
  "private": true,
  "description": "Peer engine container for SignalK image lifecycle, version switching, and self-update",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-updater-server.git"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write . && eslint src --fix",
    "ci-lint": "eslint src && prettier --check .",
    "build:all": "npm run lint && npm run build && npm test"
  },
  "dependencies": {
    "@homebridge/dbus-native": "^0.6.0",
    "dockerode": "^4.0.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
