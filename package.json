{
  "name": "signalk-updater-server",
  "version": "0.6.5",
  "private": true,
  "description": "Peer engine container for SignalK image lifecycle, version switching, and self-update",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-updater-server.git"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:plugin && npm run build:webapp",
    "build:plugin": "rimraf dist && tsc -p tsconfig.json",
    "build:webapp": "rimraf public && vite build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:webapp": "vite",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write . && eslint . --fix",
    "ci-lint": "eslint . && prettier --check .",
    "build:all": "npm run lint && npm run build && npm test"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "dockerode": "^5.0.0",
    "fastify": "^5.0.0",
    "pino": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dockerode": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "bootstrap": "^5.3.8",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reactstrap": "^9.2.3",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
